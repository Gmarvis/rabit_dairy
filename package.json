{
  "name": "rabbit-diary",
  "private": true,
  "version": "0.1.0",
  "description": "Personal finance tracker — Expo + Supabase, DDD/CQRS monorepo",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-is": "19.1.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "start": "npm run start -w @rabbit/mobile",
    "android": "npm run android -w @rabbit/mobile",
    "ios": "npm run ios -w @rabbit/mobile"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
