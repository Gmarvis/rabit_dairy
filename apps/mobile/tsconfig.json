  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@rabbit/domain": ["../../packages/domain/src/index.ts"],
      "@rabbit/application": ["../../packages/application/src/index.ts"],
